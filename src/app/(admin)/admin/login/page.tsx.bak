"use client";

import { useState } from "react";

export default function AdminLoginPage() {
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [msg, setMsg] = useState("");

  async function login() {
    setMsg("");
    const r = await fetch("/admin/api/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email, password }),
    });
    const j = await r.json().catch(() => ({}));
    if (!r.ok) {
      setMsg(j?.message || "Invalid details");
      return;
    }
    window.location.href = "/admin";
  }

  return (
    <div className="min-h-[70vh] flex items-center justify-center px-4">
      <div className="w-full max-w-md rounded-2xl border bg-white p-6">
        <h1 className="text-2xl font-semibold">Admin sign in</h1>

        <label className="mt-6 block text-sm font-medium">Email</label>
        <input
          value={email}
          onChange={(e) => setEmail(e.target.value)}
          type="email"
          className="mt-2 w-full rounded-xl border px-3 py-2"
        />

        <label className="mt-4 block text-sm font-medium">Password</label>
        <input
          value={password}
          onChange={(e) => setPassword(e.target.value)}
          type="password"
          className="mt-2 w-full rounded-xl border px-3 py-2"
        />

        {msg && <div className="mt-4 text-sm text-gray-700">{msg}</div>}

        <button onClick={login} className="mt-6 w-full rounded-xl bg-black px-4 py-2 text-white">
          Sign in
        </button>
      </div>
    </div>
  );
}
