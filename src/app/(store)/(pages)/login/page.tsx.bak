"use client";

import { useState } from "react";

export default function LoginPage() {
  const [email, setEmail] = useState("");
  const [pin, setPin] = useState("");
  const [step, setStep] = useState<"email" | "pin">("email");
  const [msg, setMsg] = useState<string>("");

  async function requestPin() {
    setMsg("");
    const r = await fetch("/api/auth/request-pin", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email }),
    });
    if (!r.ok) {
      setMsg("Please check your email and try again.");
      return;
    }
    setStep("pin");
    setMsg("We sent a code to your email.");
  }

  async function verifyPin() {
    setMsg("");
    const r = await fetch("/api/auth/verify-pin", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email, pin }),
    });
    const j = await r.json().catch(() => ({}));
    if (!r.ok) {
      setMsg(j?.message || "Invalid code. Try again.");
      return;
    }
    const next = new URLSearchParams(window.location.search).get("next") || "/";
    window.location.href = next;
  }

  return (
    <div className="min-h-[70vh] flex items-center justify-center px-4">
      <div className="w-full max-w-md rounded-2xl border bg-white p-6">
        <h1 className="text-2xl font-semibold">Sign in</h1>
        <p className="mt-2 text-sm text-gray-600">Use your email to get a 6-digit code.</p>

        <label className="mt-6 block text-sm font-medium">Email</label>
        <input
          value={email}
          onChange={(e) => setEmail(e.target.value)}
          type="email"
          className="mt-2 w-full rounded-xl border px-3 py-2"
          placeholder="you@example.com"
        />

        {step === "pin" && (
          <>
            <label className="mt-4 block text-sm font-medium">Code</label>
            <input
              value={pin}
              onChange={(e) => setPin(e.target.value)}
              inputMode="numeric"
              className="mt-2 w-full rounded-xl border px-3 py-2 tracking-widest text-center"
              placeholder="123456"
              maxLength={6}
            />
          </>
        )}

        {msg && <div className="mt-4 text-sm text-gray-700">{msg}</div>}

        <div className="mt-6 flex gap-3">
          {step === "email" ? (
            <button onClick={requestPin} className="w-full rounded-xl bg-black px-4 py-2 text-white">
              Send code
            </button>
          ) : (
            <button onClick={verifyPin} className="w-full rounded-xl bg-black px-4 py-2 text-white">
              Sign in
            </button>
          )}
        </div>
      </div>
    </div>
  );
}
