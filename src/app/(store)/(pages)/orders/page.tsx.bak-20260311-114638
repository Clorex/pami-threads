                <ul className="mt-2 space-y-1 text-sm text-gray-700">
                  {(o.items || []).map((i, idx) => (
                    <li key={`${o.id}-${idx}`}>
                      {i.quantity} Ã— {i.title}
                      {i.pick ? (
                        <span className="text-gray-500">
                          {" "}
                          ({[i.pick.fabric, i.pick.size, i.pick.color].filter(Boolean).join(" â€¢ ")})
                        </span>
                      ) : null}
                    </li>
                  ))}
                </ul>

                {(o.trackingUrl || o.trackingCode) ? (
