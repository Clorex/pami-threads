import Link from "next/link";
import { listActiveProducts } from "@/lib/firebase";
import { cldImageUrl } from "@/lib/cloudinary/url";
import { ProductCard } from "@/components/store/ProductCard";
import { Sparkles, Scissors, Users, ShieldCheck } from "lucide-react";
import clsx from "clsx";

export const revalidate = 60;

export default async function HomePage() {
  const products = await listActiveProducts(24);

  const newArrivals = products.slice(0, 4);

  const bestSellers = products
    .filter((p) => (p.collections || []).some((c) => c.toLowerCase().includes("best")))
    .slice(0, 4);

  const collections = [
    { name: "Ankara", href: "/shop?fabric=Ankara" },
    { name: "Adire", href: "/shop?fabric=Adire" },
    { name: "Linen", href: "/shop?fabric=Linen" },
    { name: "Asooke", href: "/shop?fabric=Asooke" },
    { name: "Polo Fabric", href: "/shop?fabric=Polo" },
  ];

  const features = [
    { title: "Handmade Fabrics", desc: "Every piece is crafted by hand with care and precision.", Icon: Scissors, accent: "border-pt-green" },
    { title: "African Heritage", desc: "Celebrating traditional fabrics like Ankara, Adire, and Asooke.", Icon: Sparkles, accent: "border-pt-orange" },
    { title: "Unisex Fashion", desc: "Stylish, modern designs made for everyone.", Icon: Users, accent: "border-pt-red" },
    { title: "Quality Craftsmanship", desc: "Premium materials and attention to every detail.", Icon: ShieldCheck, accent: "border-pt-green" },
  ];

  function thumbUrl(p: typeof products[number]) {
    const img = p.images?.[0];
    if (!img) return "/placeholder.png";
    return cldImageUrl(img.publicId, { width: 700, height: 900, crop: "fill", quality: "auto", format: "auto" });
  }

  function gridCols(n: number) {
    if (n <= 1) return "lg:grid-cols-1";
    if (n === 2) return "lg:grid-cols-2";
    if (n === 3) return "lg:grid-cols-3";
    return "lg:grid-cols-4";
  }

  return (
    <div>
      <section className="relative overflow-hidden">
        <div className="absolute inset-0 bg-gradient-to-br from-pt-green via-pt-orange to-pt-red opacity-90" />
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_20%_10%,rgba(255,255,255,0.22),transparent_45%),radial-gradient(circle_at_80%_30%,rgba(255,255,255,0.12),transparent_45%)]" />

        <div className="relative mx-auto flex min-h-[72vh] max-w-7xl flex-col items-center justify-center px-4 py-16 text-center text-white">
          <div className="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 text-xs font-semibold tracking-wide">
            <span className="h-2 w-2 rounded-full bg-white" />
            Handmade • Bold prints • Unisex
          </div>

          <h1 className="mt-6 text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl text-white">
            Bold African Fabrics.
            <br />
            Modern Unisex Style.
          </h1>

          <p className="mx-auto mt-4 max-w-2xl text-base text-white/90 sm:text-lg">
            Handmade African fashion for everyone. Vibrant fabrics, modern designs, crafted with culture.
          </p>

          <div className="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <Link href="/shop" className="inline-flex items-center justify-center rounded-xl bg-white px-8 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-100">
              Shop now
            </Link>
            <Link href="/shop" className="inline-flex items-center justify-center rounded-xl border border-white/45 bg-white/10 px-8 py-3 text-sm font-semibold text-white hover:bg-white/15">
              Browse fabrics
            </Link>
          </div>

          <div className="mt-10 flex flex-wrap items-center justify-center gap-2">
            {collections.map((c) => (
              <Link key={c.name} href={c.href} className="rounded-full bg-white/15 px-4 py-2 text-xs font-semibold text-white hover:bg-white/20">
                {c.name}
              </Link>
            ))}
          </div>
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-4 py-14">
        <h2 className="text-center text-2xl font-bold text-pt-green">What Makes Pami Threads Special</h2>
        <div className="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {features.map(({ title, desc, Icon, accent }) => (
            <div key={title} className={clsx("rounded-2xl border bg-white p-6 shadow-sm transition hover:shadow-md", "border-t-4", accent)}>
              <div className="flex items-center gap-3">
                <div className="rounded-xl bg-gray-50 p-2">
                  <Icon className="h-5 w-5 text-gray-800" />
                </div>
                <div className="text-base font-semibold text-gray-900">{title}</div>
              </div>
              <p className="mt-3 text-sm leading-6 text-gray-600">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-4 py-10">
        <div className="flex items-end justify-between gap-4">
          <h2 className="text-xl font-bold text-pt-green sm:text-2xl">New Arrivals</h2>
          <Link href="/shop" className="text-sm font-semibold text-gray-700 hover:text-pt-orange">
            View all
          </Link>
        </div>

        {newArrivals.length ? (
          <div className={clsx("mt-6 grid grid-cols-2 gap-4 sm:gap-6", gridCols(newArrivals.length))}>
            {newArrivals.map((p) => (
              <ProductCard key={p.id} slug={p.slug} title={p.title} priceCents={p.priceCents} imageUrl={thumbUrl(p)} />
            ))}
          </div>
        ) : (
          <div className="mt-6 rounded-2xl border bg-white p-10 text-center text-sm text-gray-600">
            No products yet. Add products in Admin → Products.
          </div>
        )}
      </section>

      <section className="bg-gray-50 py-14">
        <div className="mx-auto max-w-7xl px-4">
          <h2 className="text-center text-xl font-bold text-pt-green sm:text-2xl">Shop by Fabric</h2>
          <div className="mt-8 flex flex-wrap justify-center gap-3">
            {collections.map((c) => (
              <Link key={c.name} href={c.href} className="rounded-full border bg-white px-5 py-2.5 text-sm font-semibold text-gray-900 hover:border-pt-orange hover:text-pt-orange">
                {c.name}
              </Link>
            ))}
          </div>
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-4 py-10">
        <div className="flex items-end justify-between gap-4">
          <h2 className="text-xl font-bold text-pt-green sm:text-2xl">Best Sellers</h2>
          <Link href="/shop" className="text-sm font-semibold text-gray-700 hover:text-pt-orange">
            View all
          </Link>
        </div>

        {bestSellers.length ? (
          <div className={clsx("mt-6 grid grid-cols-2 gap-4 sm:gap-6", gridCols(bestSellers.length))}>
            {bestSellers.map((p) => (
              <ProductCard key={p.id} slug={p.slug} title={p.title} priceCents={p.priceCents} imageUrl={thumbUrl(p)} />
            ))}
          </div>
        ) : (
          <div className="mt-6 rounded-2xl border bg-white p-10 text-center text-sm text-gray-600">
            Mark products with a collection containing "best" (e.g. "Best Sellers") to show them here.
          </div>
        )}
      </section>

      <section className="mx-auto max-w-7xl px-4 py-14">
        <div className="overflow-hidden rounded-3xl border bg-white">
          <div className="relative p-8 sm:p-12">
            <div className="absolute inset-0 bg-gradient-to-r from-pt-red via-pt-orange to-pt-green opacity-15" />
            <div className="relative text-center">
              <h2 className="text-2xl font-extrabold text-gray-900">Follow Pami Threads</h2>
              <p className="mx-auto mt-3 max-w-2xl text-sm text-gray-600">
                See new drops, styling ideas, and behind-the-scenes from our studio.
              </p>

              <div className="mt-7 flex flex-col justify-center gap-3 sm:flex-row">
                <Link href="/shop" className="rounded-xl bg-pt-green px-6 py-3 text-sm font-semibold text-white hover:bg-pt-green-hover">
                  Shop latest
                </Link>
                <a
                  href={(process.env.NEXT_PUBLIC_INSTAGRAM_URL || "#").toString()}
                  className="rounded-xl border px-6 py-3 text-sm font-semibold text-gray-900 hover:border-pt-orange hover:text-pt-orange"
                >
                  Instagram
                </a>
              </div>

              <div className="mt-4 text-xs text-gray-500">(Add your Instagram URL in NEXT_PUBLIC_INSTAGRAM_URL)</div>
            </div>
          </div>
        </div>
      </section>
    </div>
  );
}